# ====================================================
# RIOS — .gitignore
# ====================================================

# Environment config
# NOTE: env.js contains only the PUBLIC anon key (safe to commit).
# NEVER commit the service_role key here.
# env.js is tracked in Git for Vercel deployment.
# env.secret.js  ← put service_role key here and keep THIS gitignored
env.secret.js

# OS artifacts
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Logs
*.log

# Node (if ever added)
node_modules/
